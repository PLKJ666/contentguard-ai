# ===========================
# 后端业务配置（模板）
# DB/Redis/Logto 由根目录 .env 通过 docker-compose 注入，不在此文件配置
# 复制为 .env 并填写实际值: cp .env.example .env
# ===========================

# --- 应用 ---
APP_NAME=ContentGuard AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# --- CORS（填写实际访问地址，多个逗号分隔）---
CORS_ORIGINS=https://your-domain.com

# --- Application encryption ---
# 生产环境务必更换: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# --- 文件上传 ---
MAX_FILE_SIZE_MB=500
# Leave empty to keep operator onboarding closed; set only through deployment secrets.
OPERATOR_ACCESS_CODE=

# --- 火山引擎 TOS（对象存储）---
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_BUCKET_NAME=contentguard-files
TOS_ENDPOINT=
TOS_CDN_DOMAIN=
LOCAL_FILE_STORAGE_ENABLED=false
LOCAL_FILE_STORAGE_PREFER_UPLOAD=false
LOCAL_FILE_STORAGE_FALLBACK_ON_UPLOAD_ERROR=false
