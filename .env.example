# ═══════════════════════════════════════════
# Docker Compose 编排配置（生产环境模板）
# 负责：端口、外部服务地址、前端/Logto 认证
# PostgreSQL/Redis 在本机独立运行，通过 host.docker.internal 连接
# 复制为 .env 并填写实际值
# ═══════════════════════════════════════════

# --- 端口（主机端口，按实际情况修改）---
NGINX_PORT=80
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- 外部服务地址 ---
DATABASE_URL=postgresql+asyncpg://contentguard:<password>@host.docker.internal:5432/contentguard
REDIS_URL=redis://host.docker.internal:6379/0

# --- 前端 ---
# 必须是用户实际访问的地址（例如直连 Next :3000 或通过 nginx），Logto 回调依赖此值
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# --- Logto 认证（前端+后端共用）---
LOGTO_ENDPOINT=https://auth.example.com/
LOGTO_APP_ID=
LOGTO_APP_SECRET=
# Generate locally; do not commit the generated value.
LOGTO_COOKIE_SECRET=
LOGTO_API_RESOURCE=https://api.example.com
